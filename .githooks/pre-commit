#!/usr/bin/env bash
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
if [[ -f scripts/validate-ruleset.sh ]]; then
  changed="$(git diff --cached --name-only --diff-filter=AMR | grep '^ruleset/' | head -20 || true)"
  if [[ -n "$changed" ]]; then
    echo "🔍 校验 ruleset 格式..."
    for f in $changed; do
      if [[ -f "$f" ]]; then
        bash scripts/validate-ruleset.sh "$f" 2>&1
        git add "$f" 2>/dev/null || true
      fi
    done
  fi
fi
